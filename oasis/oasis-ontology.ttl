	rdfs:domain oasis:ImpactAssessment ;
	rdfs:range rdfs:Literal ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .
	
oasis:publishedOn rdf:type owl:DatatypeProperty ;
	rdfs:label "Published on"@en ;
	rdfs:comment ""@en ;
	rdfs:domain oasis:ImpactAssessment ;
	rdfs:range xsd:date ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .
		
