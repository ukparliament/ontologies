	rdfs:label "Has committee"@en ;
	rdfs:comment "."@en ;
	rdfs:domain oasis:CommitteeProceeding ;
	rdfs:range oasis:OrganisationTerm ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .	
	
oasis:formalProceedingHasCommittee rdf:type owl:ObjectProperty ;
	rdfs:label "Formal proceeding has committee"@en ;
	rdfs:comment "."@en ;
	rdfs:domain oasis:FormalProceeding ;
	rdfs:range oasis:OrganisationTerm ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .	
	
oasis:formalProceedingHasSpeaker rdf:type owl:ObjectProperty ;
	rdfs:label "Formal proceeding has Speaker"@en ;
	rdfs:comment "."@en ;
	rdfs:domain oasis:FormalProceeding ;
	rdfs:range oasis:OrganisationTerm ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .	
	
oasis:formalProceedingHasGovernmentDepartment rdf:type owl:ObjectProperty ;
	rdfs:label "Formal proceeding has government department"@en ;
	rdfs:comment "."@en ;
	rdfs:domain oasis:FormalProceeding ;
	rdfs:range oasis:GovernmentDepartmentTerm ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .	


				

#######  Data properties #####

oasis:title rdf:type owl:DatatypeProperty ;
	rdfs:label "Title"@en ;
	rdfs:comment "The title of an OaSIS record."@en ;
	rdfs:domain oasis:Record ;
	rdfs:range rdf:langString ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .
	
oasis:webLocation rdf:type owl:DatatypeProperty ;
	rdfs:label "Web location"@en ;
	rdfs:comment ""@en ;
	rdfs:domain oasis:Record ;
	rdfs:range rdfs:Literal ;
	rdfs:isDefinedBy <http://parliament.uk/ontologies/oasis/> .
	
